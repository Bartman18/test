# ── Amplify / React environment variables ────────────────────────────────────
# Copy this file to .env (or .env.local) and fill in the values from
# `cdk deploy` outputs. Never commit the filled .env file to source control.
#
# How to get these values:
#   cdk deploy --outputs-file cdk-outputs.json
#   Then read cdk-outputs.json for each stack.
#
# ── Cognito (CognitoStack outputs) ───────────────────────────────────────────
REACT_APP_USER_POOL_ID=<CognitoStack.UserPoolId>
REACT_APP_USER_POOL_CLIENT_ID=<CognitoStack.UserPoolClientId>
REACT_APP_IDENTITY_POOL_ID=<CognitoStack.IdentityPoolId>

# ── API Gateway (ApiStack outputs) ───────────────────────────────────────────
# IMPORTANT: Must include the stage name (/prod).
# Example: https://abc123.execute-api.eu-central-1.amazonaws.com/prod
# (copy the value of ApiStack.ApiUrl and strip the trailing slash)
REACT_APP_API_URL=<ApiStack.ApiUrl>

# ── DynamoDB (DatabaseStack outputs) ─────────────────────────────────────────
REACT_APP_TABLE_NAME=Recommendations

# ── AWS Region ────────────────────────────────────────────────────────────────
REACT_APP_AWS_REGION=eu-central-1
